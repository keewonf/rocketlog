{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["node", "jest"],
    "resolveJsonModule": true,
    "strict": true,
    "sourceMap": true,
    "noEmitOnError": true,

    "isolatedModules": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
