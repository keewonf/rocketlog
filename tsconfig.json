{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],

    "paths": {
      "@/*": ["./src/*"]
    },

    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "resolveJsonModule": true,
    "strict": true,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
